---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Section from '@components/Section.astro';
import InstructorCard from '@components/InstructorCard.astro';
import ScheduleTable from '@components/ScheduleTable.astro';
import ScrollReveal from '@components/ScrollReveal.astro';
import Button from '@components/Button.astro';
import { useTranslations, getLocalizedPath } from '@i18n/utils';
import type { ScheduleEntry } from '@components/ScheduleTable.astro';

const lang = 'en';
const t = useTranslations(lang);

const schedule: ScheduleEntry[] = [
  { day: 'Monday', time: '7:00 - 8:30 PM', className: 'Folk Dance', instructor: t('instructor1.name') },
  { day: 'Wednesday', time: '7:00 - 8:30 PM', className: 'Latin Dance', instructor: t('instructor2.name') },
  { day: 'Friday', time: '7:00 - 8:30 PM', className: 'Modern Dance', instructor: t('instructor1.name') },
  { day: 'Saturday', time: '10:00 - 11:30 AM', className: 'Jazz', instructor: t('instructor2.name') },
];
---
<BaseLayout
  title={t('seo.home.title')}
  description={t('seo.home.description')}
  lang={lang}
  currentPath="/"
>
  <Hero
    title={t('hero.title')}
    subtitle={t('hero.subtitle')}
    ctaText={t('hero.cta')}
    ctaHref={getLocalizedPath(lang, '/contact/')}
  />

  <Section id="about">
    <ScrollReveal>
      <h2 class="section-title">{t('about.title')}</h2>
    </ScrollReveal>
    <ScrollReveal delay={200}>
      <p class="text-center">{t('about.description')}</p>
    </ScrollReveal>
  </Section>

  <Section id="instructors" background="surface">
    <ScrollReveal>
      <h2 class="section-title">{t('instructors.title')}</h2>
    </ScrollReveal>
    <div class="instructors-grid">
      <ScrollReveal animation="fade-up" delay={200}>
        <InstructorCard
          name={t('instructor1.name')}
          role={t('instructor1.role')}
          bio={t('instructor1.bio')}
          specialties={t('instructor1.specialties').split(',')}
        />
      </ScrollReveal>
      <ScrollReveal animation="fade-up" delay={400}>
        <InstructorCard
          name={t('instructor2.name')}
          role={t('instructor2.role')}
          bio={t('instructor2.bio')}
          specialties={t('instructor2.specialties').split(',')}
        />
      </ScrollReveal>
    </div>
  </Section>

  <Section id="schedule">
    <ScrollReveal>
      <h2 class="section-title">{t('schedule.title')}</h2>
    </ScrollReveal>
    <ScrollReveal animation="fade-up" delay={200}>
      <ScheduleTable schedule={schedule} lang={lang} />
    </ScrollReveal>
  </Section>

  <Section background="surface">
    <ScrollReveal animation="scale-in">
      <div class="cta-section text-center">
        <h2>{t('contact.title')}</h2>
        <p class="text-muted">{t('contact.subtitle')}</p>
        <Button href={getLocalizedPath(lang, '/contact/')} size="lg">{t('hero.cta')}</Button>
      </div>
    </ScrollReveal>
  </Section>
</BaseLayout>

<style>
  .section-title {
    text-align: center;
    margin-bottom: var(--space-xl);
    color: var(--color-primary);
  }

  .instructors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  .cta-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }
</style>
