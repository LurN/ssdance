---
interface Props {
  title?: string;
  id?: string;
  background?: 'default' | 'surface';
  narrow?: boolean;
}

const { title, id, background = 'default', narrow = false } = Astro.props;
---
<section id={id} class:list={['section', `section--${background}`, { 'section--narrow': narrow }]}>
  <div class="section__container">
    {title && <h2 class="section__title">{title}</h2>}
    <slot />
  </div>
</section>

<style>
  .section {
    padding: var(--space-2xl) 0;
  }

  .section--surface {
    background-color: var(--color-surface);
  }

  .section__container {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-md);
  }

  .section--narrow .section__container {
    max-width: 800px;
  }

  .section__title {
    text-align: center;
    margin-bottom: var(--space-xl);
    color: var(--color-primary);
  }
</style>
