---
import type { Lang } from '@i18n/languages';
import { getAlternateLang, getLocalizedPath } from '@i18n/utils';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  currentPath: string;
  ogImage?: string;
}

const { title, description, lang, currentPath, ogImage } = Astro.props;
const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalUrl = `${site}${base}/${lang}${currentPath}`;
const altLang = getAlternateLang(lang);
const altUrl = `${site}${base}/${altLang}${currentPath}`;
---
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<link rel="alternate" hreflang={lang} href={canonicalUrl} />
<link rel="alternate" hreflang={altLang} href={altUrl} />
<link rel="alternate" hreflang="x-default" href={`${site}${base}/zh${currentPath}`} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content="website" />
<meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
{ogImage && <meta property="og:image" content={`${site}${ogImage}`} />}

<!-- Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "SS Dance Studio",
  "alternateName": "SS Dance 舞蹈工作室",
  "description": description,
  "url": site,
  "image": ogImage ? `${site}${ogImage}` : undefined,
})} />
